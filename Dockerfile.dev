FROM node:20-alpine

WORKDIR /app

# Copy package files and install all dependencies (including devDependencies)
COPY package*.json ./
RUN npm install

# Copy source code
COPY . .

# Expose SvelteKit default dev port
EXPOSE 5173

# Run Vite dev server bound to 0.0.0.0 so Docker can map the network
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
